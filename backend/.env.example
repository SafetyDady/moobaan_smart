# Moobaan Smart Backend — Environment Variables (TEMPLATE, ไม่มีค่าจริง)
# คัดลอกเป็น .env แล้วเติมค่า | ค่าลับจริงของ production อยู่บน Railway dashboard เท่านั้น
# Generate secret: python -c "import secrets; print(secrets.token_hex(32))"

# ── Application ───────────────────────────────────────────────
APP_NAME=moobaan_smart_backend
ENV=local                         # local | production  (production จะบังคับ COOKIE_SECURE + ตรวจ SECRET_KEY)
PORT=8000
HOST=0.0.0.0

# ── Database (PostgreSQL + psycopg v3 REQUIRED) ───────────────
# Format: postgresql+psycopg://user:password@host:port/database
# Local:   postgresql+psycopg://postgres:password@localhost:5432/moobaan_smart
# Railway: ใช้ reference ${{Postgres_moobaan.DATABASE_URL}} (อย่า hardcode ค่าจริง)
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/moobaan_smart

# ── JWT / Security ────────────────────────────────────────────
# ต้องยาว >=16 และห้ามขึ้นต้นด้วย change-this / your-secret-key / secret (prod จะ crash)
SECRET_KEY=__GENERATE_ME__

# ── Statement / สลิป (มี default ในโค้ด ปล่อยว่างได้) ──────────
PROJECT_NAME_TH=หมู่บ้านสมาร์ท
PROJECT_NAME_EN=Smart Village
ACCOUNTING_CONTACT=Tel: 02-xxx-xxxx Email: accounting@village.com

# ── Cloudflare R2 (เก็บสลิป/ไฟล์แนบ) ──────────────────────────
# ⚠️ โค้ดอ่านชื่อ R2_PUBLIC_URL (ไม่ใช่ R2_PUBLIC_BASE_URL) — ตั้งให้ตรง
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=__SET_ME__
R2_SECRET_ACCESS_KEY=__SET_ME__
R2_BUCKET_NAME=moobaan-smart-production
R2_PUBLIC_URL=https://<public-bucket>.r2.dev
# หมายเหตุ: R2_ACCOUNT_ID, R2_REGION โค้ดปัจจุบัน "ไม่ได้ใช้" (ตั้งได้แต่ไม่จำเป็น)

# ── LINE OAuth (login ลูกบ้าน) ────────────────────────────────
LINE_CHANNEL_ID=__SET_ME__
LINE_CHANNEL_SECRET=__SET_ME__
LINE_REDIRECT_URI=https://<frontend-domain>/login   # ต้องตรงกับ Callback URL ใน LINE Console

# ── OTP (ลูกบ้าน) — ⛔ เลิกใช้แล้ว (มีค่าใช้จ่าย SMS) ──────────
# ปัจจุบัน login ลูกบ้านใช้ LINE OAuth อย่างเดียว → ปิด OTP ให้ขาด
OTP_PROVIDER=disabled              # disabled = ปิด OTP สะอาด (ไม่ต้องตั้ง whitelist/mock/SMS)
# คีย์ด้านล่าง "ไม่ต้องตั้ง" เมื่อ OTP_PROVIDER=disabled — เก็บไว้เป็นอ้างอิงถ้าจะเปิดใช้ใหม่:
#   OTP_MODE, OTP_MOCK_CODE, OTP_EXPIRY_SECONDS, OTP_MAX_ATTEMPTS,
#   OTP_RATE_LIMIT, OTP_RATE_LIMIT_MAX, OTP_RATE_LIMIT_WINDOW,
#   OTP_SANDBOX_WHITELIST, OTP_VERIFY_LOCKOUT_ATTEMPTS, OTP_VERIFY_LOCKOUT_MINUTES,
#   ALLOW_MOCK_OTP_IN_PROD  (🔴 อย่าตั้ง true บน production — เป็นโหมดทดสอบเท่านั้น)
# 🔴 ถ้าเปิด OTP ใหม่ด้วย provider=mock บน production: โค้ดบังคับต้องมี OTP_SANDBOX_WHITELIST (ไม่งั้น fail)

# ── SMS provider (SMSMKT) — ⛔ ไม่ใช้แล้ว ──────────────────────
# OTP ปิดแล้ว → ไม่ต้องตั้ง SMSMKT_* และลบออกจาก Railway ได้ (กันค่าใช้จ่าย/การถูกใช้คีย์)
#   SMSMKT_API_KEY, SMSMKT_PROJECT_KEY, SMSMKT_SECRET_KEY

# ── Token lifetimes ───────────────────────────────────────────
ADMIN_ACCESS_TOKEN_MINUTES=60
ADMIN_REFRESH_TOKEN_HOURS=12
RESIDENT_ACCESS_TOKEN_MINUTES=60
RESIDENT_REFRESH_TOKEN_DAYS=30
RESIDENT_LINE_SESSION_DAYS=30

# ── Production bootstrap (ใช้ครั้งแรกแล้ว "ปิด") ───────────────
# 🔴 ตั้ง reset/seed = true แล้วค้างไว้ = ทุก deploy จะ reset รหัสแอดมิน / seed ซ้ำ
PROD_ADMIN_EMAIL=admin@example.com
PROD_ADMIN_PASSWORD=__STRONG_PASSWORD__
PROD_RESET_ADMIN_PASSWORD=false
RUN_PROD_SEED=false
